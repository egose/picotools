#!/usr/bin/env bash
set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOAD_SH="${SCRIPT_DIR}/../lib/picotools/load.sh"
if [ ! -f "$LOAD_SH" ]; then
  LOAD_SH="${SCRIPT_DIR}/../../lib/picotools/load.sh"
fi
# shellcheck source=../lib/picotools/load.sh
# shellcheck disable=SC1091
. "$LOAD_SH"
picotools_source_modules "$SCRIPT_DIR" github

github_coordinates="${ASDF_PICOTOOLS_GITHUB_REPOSITORY:-$(picotools_resolve_github_coordinates "$SCRIPT_DIR")}"
releases_url="https://api.github.com/repos/${github_coordinates}/releases"

# Use an array for headers to handle spaces/quotes safely
curl_opts=("-s")
if [ -n "$GITHUB_API_TOKEN" ]; then
  curl_opts+=("-H" "Authorization: token $GITHUB_API_TOKEN")
fi

sort_versions() {
  sed 'h; s/[+-]/./g; s/.p\([[:digit:]]\)/.z\1/; s/$/.z/; G; s/\n/ /' |
    LC_ALL=C sort -V | cut -d ' ' -f 2
}

all_tags=""

# Loop through pages 1 to 3 (300 items total)
for page in {1..3}; do
  # Construct the full URL with page params
  current_url="${releases_url}?per_page=100&page=${page}"

  # Execute curl using the array of options
  response=$(curl "${curl_opts[@]}" "$current_url")

  # Extract tag names
  tags=$(echo "$response" | grep -o '"tag_name": *"[^"]*"' | sed -E 's/"tag_name": *"v?([^"]*)"/\1/' || true)

  # If the response is empty or just "[]", break
  if [ -z "$tags" ] || [ "$response" == "[]" ]; then
    break
  fi

  all_tags="${all_tags}${tags}"$'\n'
done

# Clean up empty lines and sort
versions=$(echo "$all_tags" | sed '/^$/d' | sort_versions | xargs)

echo "$versions"
