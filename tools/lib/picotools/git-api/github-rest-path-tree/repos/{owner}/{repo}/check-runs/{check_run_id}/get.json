      "$ref": "#/components/parameters/owner"
    },
    {
      "$ref": "#/components/parameters/repo"
    },
    {
      "$ref": "#/components/parameters/check-run-id"
    }
  ],
  "responses": {
    "200": {
      "description": "Response",
      "content": {
        "application/json": {
          "schema": {
            "$ref": "#/components/schemas/check-run"
          },
          "examples": {
            "default": {
              "$ref": "#/components/examples/check-run"
            }
          }
        }
      }
    }
  },
  "x-github": {
