#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOAD_SH="${SCRIPT_DIR}/../lib/picotools/load.sh"
if [ ! -f "$LOAD_SH" ]; then
  LOAD_SH="${SCRIPT_DIR}/../../lib/picotools/load.sh"
fi
# shellcheck source=../../lib/picotools/load.sh
# shellcheck disable=SC1091
. "$LOAD_SH"
picotools_source_modules "$SCRIPT_DIR" commands git prompt version

usage() {
  cat <<'EOF'
Usage: git-clean-branches [--yes] [remote]

Deletes all local branches except the default branch and the current branch.
Deletes merged remote branches except the default branch and the current branch.

Options:
  --yes       Skip the confirmation prompt
  -h, --help, help        Show this help message
  -v, --version, version  Show the tool version

Arguments:
  remote      Remote name to clean (default: origin)
EOF
}

print_version() {
  picotools_print_version "$SCRIPT_DIR"
}

main() {
  local assume_yes=false
  local remote=origin
  local remote_set=false
  local arg

  for arg in "$@"; do
    case "$arg" in
    --yes)
      assume_yes=true
      ;;
    -h | --help | help)
      usage
      exit 0
      ;;
    -v | --version | version)
      print_version
      exit 0
      ;;
    *)
      if [ "$remote_set" = true ]; then
        echo "Error: unexpected argument: $arg" >&2
        usage >&2
        exit 1
      fi
      remote="$arg"
      remote_set=true
      ;;
    esac
  done

  picotools_require_git_repo

  if ! git remote get-url "$remote" >/dev/null 2>&1; then
    echo "Error: remote '$remote' does not exist" >&2
    exit 1
  fi

  local current_branch
  current_branch=$(git branch --show-current)
  if [ -z "$current_branch" ]; then
    echo "Error: detached HEAD is not supported" >&2
    exit 1
  fi

  git fetch "$remote" --prune

  local default_branch
  default_branch=$(picotools_git_default_branch "$remote")
  if [ -z "$default_branch" ]; then
    echo "Error: could not determine the default branch for remote '$remote'" >&2
    exit 1
  fi

  local local_branches=()
  local remote_branches=()
  local worktree_branches=()
  local branch ref line worktree_branch in_worktree

  while IFS= read -r line; do
    case "$line" in
    branch\ refs/heads/*)
      worktree_branches+=("${line#branch refs/heads/}")
      ;;
    esac
  done < <(git worktree list --porcelain)

  while IFS= read -r branch; do
    [ -z "$branch" ] && continue
    [ "$branch" = "$default_branch" ] && continue
    [ "$branch" = "$current_branch" ] && continue

    in_worktree=false
    for worktree_branch in "${worktree_branches[@]}"; do
      if [ "$branch" = "$worktree_branch" ]; then
        in_worktree=true
        break
      fi
    done
    [ "$in_worktree" = true ] && continue

    local_branches+=("$branch")
  done < <(git for-each-ref --format='%(refname:short)' refs/heads)

  while IFS= read -r ref; do
    [ -z "$ref" ] && continue
    [ "$ref" = "refs/remotes/${remote}/HEAD" ] && continue

    branch=${ref#"refs/remotes/${remote}/"}
    [ "$branch" = "$default_branch" ] && continue
    [ "$branch" = "$current_branch" ] && continue

    remote_branches+=("$branch")
  done < <(git for-each-ref --format='%(refname)' --merged "refs/remotes/${remote}/${default_branch}" "refs/remotes/${remote}")

  printf 'Remote: %s\n' "$remote"
  printf 'Default branch: %s\n' "$default_branch"
  printf 'Current branch: %s\n' "$current_branch"

  if [ "${#local_branches[@]}" -eq 0 ] && [ "${#remote_branches[@]}" -eq 0 ]; then
    echo "Nothing to delete."
    exit 0
  fi

  if [ "${#local_branches[@]}" -gt 0 ]; then
    echo "Local branches to delete:"
    printf '  %s\n' "${local_branches[@]}"
  fi

  if [ "${#remote_branches[@]}" -gt 0 ]; then
    echo "Remote branches to delete:"
    printf '  %s\n' "${remote_branches[@]}"
  fi

  if [ "$assume_yes" != true ]; then
    picotools_confirm_action "Proceed with deleting these branches?" || exit 1
  fi

  for branch in "${local_branches[@]}"; do
    git branch -D "$branch"
  done

  for branch in "${remote_branches[@]}"; do
    git push "$remote" --delete "$branch"
  done
}

main "$@"
