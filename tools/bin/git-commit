#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOAD_SH="${SCRIPT_DIR}/../lib/picotools/load.sh"
if [ ! -f "$LOAD_SH" ]; then
  LOAD_SH="${SCRIPT_DIR}/../../lib/picotools/load.sh"
fi
# shellcheck source=../../lib/picotools/load.sh
# shellcheck disable=SC1091
. "$LOAD_SH"
picotools_source_modules "$SCRIPT_DIR" prompt version

ALLOWED_TYPES='feat fix docs refactor chore perf test ci'
MAX_COMMIT_PLAN_CHANGED_FILES_CHARS=250000
MAX_COMMIT_PLAN_DIFF_CHARS=50000
MAX_COMMIT_PLAN_FILE_DIFF_CHARS=16384
MAX_COMMIT_PLAN_ADDED_FILE_BYTES=65536

usage() {
  cat <<'EOF'
Usage: git-commit [command]

Commands:
  configure  Select the model profile and model to use

Without a command, `git-commit` analyzes the current git workspace, asks the
configured model for conventional commit suggestions, and creates one or more
commits.

Options:
  -h, --help, help          Show this help message
  -v, --version, version    Show the tool version
  --debug                   Print progress steps to stderr
  --apply                   Stage files and create the generated commit plan
  --push                    With --apply, push the created commits
  --pre-commit-retries <n>  Retry failed pre-commit checks this many times
  --scope <value>           Override commit scope for generated titles
  --no-scope                Omit scope from generated titles
EOF
}

print_version() {
  picotools_print_version "$SCRIPT_DIR"
}

debug_enabled() {
  [ "${GIT_COMMIT_DEBUG:-false}" = 'true' ]
}

debug_log() {
  if debug_enabled; then
    printf '[git-commit] %s\n' "$1" >&2
  fi
}

enable_debug_logging() {
  GIT_COMMIT_DEBUG=true
}

config_dir() {
  printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}/git-commit"
}

config_file() {
  printf '%s/config\n' "$(config_dir)"
}

ensure_config_dir() {
  mkdir -p "$(config_dir)"
}

write_config_value() {
  local key="$1"
  local value="$2"

  ensure_config_dir
  git config -f "$(config_file)" "$key" "$value"
}

read_config_value_optional() {
  local key="$1"

  git config -f "$(config_file)" --get "$key" 2>/dev/null || true
}

prompt_value() {
  picotools_prompt_value "$@"
}

prompt_yes_no() {
  picotools_prompt_yes_no "$@"
}

model_provider_command() {
  local candidate

  if [ -n "${MODEL_PROVIDER_BIN:-}" ]; then
    printf '%s\n' "$MODEL_PROVIDER_BIN"
    return 0
  fi

  candidate="${SCRIPT_DIR}/model-provider"
  if [ -x "$candidate" ]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  if command -v model-provider >/dev/null 2>&1; then
    command -v model-provider
    return 0
  fi

  echo 'Error: unable to locate model-provider' >&2
  exit 1
}

run_model_provider() {
  local tool

  tool=$(model_provider_command)
  if debug_enabled; then
    MODEL_PROVIDER_DEBUG=true "$tool" "$@"
    return $?
  fi

  "$tool" "$@"
}

require_git_repository() {
  if [ "$(git rev-parse --is-inside-work-tree 2>/dev/null || true)" != 'true' ]; then
    echo 'Error: git-commit must be run inside a Git repository' >&2
    exit 1
  fi
}

require_dependencies() {
  local tool

  for tool in git jq; do
    if ! command -v "$tool" >/dev/null 2>&1; then
      echo "Error: required tool not found: $tool" >&2
      exit 1
    fi
  done

  model_provider_command >/dev/null
}

require_runtime_dependencies() {
  require_git_repository
  require_dependencies
}

select_from_list() {
  local header="$1"
  local prompt="$2"
  shift 2
  local -a items=("$@")
  local selection

  if [ "${#items[@]}" -eq 0 ]; then
    echo "Error: no options available for $header" >&2
    exit 1
  fi

  if ! selection=$(picotools_prompt_select_index "$header" "$prompt" 1 false "${items[@]}"); then
    return 1
  fi

  printf '%s\n' "${items[$((selection - 1))]}"
}

configure_tool() {
  local profile model
  local -a profiles=()
  local -a models=()

  model_provider_command >/dev/null
  mapfile -t profiles < <(run_model_provider profiles)
  if [ "${#profiles[@]}" -eq 0 ]; then
    echo 'Error: no model-provider profiles found' >&2
    exit 1
  fi

  if ! profile=$(select_from_list 'Profiles' 'Select profile' "${profiles[@]}"); then
    echo 'Cancelled.' >&2
    exit 1
  fi
  mapfile -t models < <(run_model_provider models "$profile")
  if [ "${#models[@]}" -eq 0 ]; then
    echo "Error: no models configured for profile '$profile'" >&2
    exit 1
  fi

  if ! model=$(select_from_list 'Models' 'Select model' "${models[@]}"); then
    echo 'Cancelled.' >&2
    exit 1
  fi
  write_config_value model.profile "$profile"
  write_config_value model.name "$model"
  echo "Configured git-commit with profile '$profile' and model '$model'."
}

load_configuration() {
  local profile model

  profile=$(read_config_value_optional model.profile)
  model=$(read_config_value_optional model.name)

  if [ -z "$profile" ] || [ -z "$model" ]; then
    echo 'Warning: git-commit is not configured. Run git-commit configure.' >&2
    exit 1
  fi

  printf '%s\t%s\n' "$profile" "$model"
}

ensure_changes_exist() {
  local status

  status=$(git status --porcelain)
  if [ -z "$status" ]; then
    echo 'Error: no file changes found in the current git workspace' >&2
    exit 1
  fi
}

ensure_no_staged_changes() {
  local staged_status unstage_changes

  staged_status=$(git diff --cached --name-only)
  if [ -n "$staged_status" ]; then
    unstage_changes=$(prompt_yes_no 'Staged changes detected. Unstage them with git restore --staged :/?' no)
    if [ "$unstage_changes" = 'yes' ]; then
      git restore --staged :/
      return 0
    fi

    echo 'Error: git-commit requires no pre-staged changes. Unstage them first.' >&2
    exit 1
  fi
}

current_branch_name() {
  local branch

  branch=$(git branch --show-current)
  if [ -z "$branch" ]; then
    echo 'Error: detached HEAD is not supported' >&2
    exit 1
  fi

  printf '%s\n' "$branch"
}

git_repo_root() {
  git rev-parse --show-toplevel
}

derive_scope_from_branch() {
  local branch="$1"
  local last_segment

  if [[ "$branch" != */* ]]; then
    printf '\n'
    return 0
  fi

  last_segment=${branch##*/}
  if [[ "$last_segment" =~ ^([0-9]+)([_-].*)?$ ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi

  printf '%s\n' "$last_segment"
}

repo_has_workspace_manifest() {
  local repo_root="$1"
  local manifest

  for manifest in pnpm-workspace.yaml lerna.json nx.json turbo.json rush.json go.work; do
    if [ -f "$repo_root/$manifest" ]; then
      return 0
    fi
  done

  return 1
}

package_json_declares_workspaces() {
  local repo_root="$1"
  local package_json="$repo_root/package.json"

  if [ ! -f "$package_json" ]; then
    return 1
  fi

  grep -Eq '"workspaces"[[:space:]]*:' "$package_json"
}

count_nested_module_manifests() {
  local repo_root="$1"
  local path count=0

  while IFS= read -r path; do
    [ -n "$path" ] || continue
    case "$path" in
    package.json | pyproject.toml | go.mod | Cargo.toml)
      continue
      ;;
    */package.json | */pyproject.toml | */go.mod | */Cargo.toml)
      count=$((count + 1))
      if [ "$count" -ge 2 ]; then
        printf '%s\n' "$count"
        return 0
      fi
      ;;
    esac
  done < <(git -C "$repo_root" ls-files --cached --others --exclude-standard -- '*/package.json' '*/pyproject.toml' '*/go.mod' '*/Cargo.toml')

  printf '%s\n' "$count"
}

repo_is_monorepo() {
  local repo_root="$1"
  local nested_manifest_count

  if repo_has_workspace_manifest "$repo_root" || package_json_declares_workspaces "$repo_root"; then
    return 0
  fi

  nested_manifest_count=$(count_nested_module_manifests "$repo_root")
  [ "$nested_manifest_count" -ge 2 ]
}

module_dir_for_file() {
  local repo_root="$1"
  local file="$2"
  local dir parent

  case "$file" in
  */*)
    dir=${file%/*}
    ;;
  *)
    return 1
    ;;
  esac

  while [ -n "$dir" ] && [ "$dir" != '.' ]; do
    if [ -f "$repo_root/$dir/package.json" ] || [ -f "$repo_root/$dir/pyproject.toml" ] || [ -f "$repo_root/$dir/go.mod" ] || [ -f "$repo_root/$dir/Cargo.toml" ]; then
      printf '%s\n' "$dir"
      return 0
    fi

    parent=${dir%/*}
    if [ "$parent" = "$dir" ]; then
      break
    fi
    dir="$parent"
  done

  return 1
}

package_name_from_manifest() {
  local package_json="$1"
  local line
  local name_pattern='"name"[[:space:]]*:[[:space:]]*"([^"]+)"'

  [ -f "$package_json" ] || return 1

  while IFS= read -r line; do
    if [[ "$line" =~ $name_pattern ]]; then
      printf '%s\n' "${BASH_REMATCH[1]}"
      return 0
    fi
  done <"$package_json"

  return 1
}

module_scope_name() {
  local repo_root="$1"
  local module_dir="$2"
  local package_name

  package_name=$(package_name_from_manifest "$repo_root/$module_dir/package.json" || true)
  if [ -n "$package_name" ]; then
    printf '%s\n' "${package_name##*/}"
    return 0
  fi

  printf '%s\n' "${module_dir##*/}"
}

derive_scope_from_monorepo() {
  local changed_files="$1"
  local repo_root file module_dir scope=''
  local -A seen_modules=()

  repo_root=$(git_repo_root)
  if ! repo_is_monorepo "$repo_root"; then
    printf '\n'
    return 0
  fi

  while IFS= read -r file; do
    [ -n "$file" ] || continue
    module_dir=$(module_dir_for_file "$repo_root" "$file" || true)
    if [ -z "$module_dir" ] || [ -n "${seen_modules[$module_dir]:-}" ]; then
      continue
    fi

    seen_modules[$module_dir]=1
    if [ -n "$scope" ] && [ "$scope" != "$module_dir" ]; then
      printf '\n'
      return 0
    fi
    scope="$module_dir"
  done <<<"$changed_files"

  if [ -z "$scope" ]; then
    printf '\n'
    return 0
  fi

  module_scope_name "$repo_root" "$scope"
}

pre_commit_hook_path() {
  git rev-parse --git-path hooks/pre-commit
}

git_index_path() {
  git rev-parse --git-path index
}

restore_index_snapshot() {
  local snapshot_path="$1"
  local index_path

  index_path=$(git_index_path)
  cp "$snapshot_path" "$index_path"
}

run_pre_commit_checks() {
  local changed_files="$1"
  local retry_count="$2"
  local hook_path index_snapshot file attempt=1
  local max_attempts=$((retry_count + 1))
  local -a files=()

  hook_path=$(pre_commit_hook_path)
  if [ ! -x "$hook_path" ]; then
    debug_log 'Skipping pre-commit checks because no executable hook was found'
    return 0
  fi

  while IFS= read -r file; do
    if [ -n "$file" ]; then
      files+=("$file")
    fi
  done <<<"$changed_files"

  if [ "${#files[@]}" -eq 0 ]; then
    debug_log 'Skipping pre-commit checks because no changed files were collected'
    return 0
  fi

  index_snapshot=$(mktemp)
  cp "$(git_index_path)" "$index_snapshot"

  debug_log "Running pre-commit hook for ${#files[@]} changed file(s)"
  echo 'Pre-commit checks:'
  while true; do
    if [ "$max_attempts" -gt 1 ]; then
      printf 'Attempt %d/%d\n' "$attempt" "$max_attempts"
    fi

    restore_index_snapshot "$index_snapshot"
    git add -A :/

    if "$hook_path"; then
      restore_index_snapshot "$index_snapshot"
      rm -f "$index_snapshot"
      printf '\n'
      return 0
    fi

    printf '\n'

    if [ "$attempt" -ge "$max_attempts" ]; then
      restore_index_snapshot "$index_snapshot"
      rm -f "$index_snapshot"
      echo "Error: pre-commit checks failed after $max_attempts attempts" >&2
      return 1
    fi

    attempt=$((attempt + 1))
  done
}

collect_changed_files() {
  local repo_root file
  local has_head=false
  local -A seen=()
  local -a files=()

  repo_root=$(git_repo_root)

  if git rev-parse --verify HEAD >/dev/null 2>&1; then
    has_head=true
  fi

  if [ "$has_head" = true ]; then
    while IFS= read -r file; do
      if [ -n "$file" ] && [ -z "${seen[$file]:-}" ]; then
        seen[$file]=1
        files+=("$file")
      fi
    done < <(git -C "$repo_root" diff --name-only HEAD --)
  else
    while IFS= read -r file; do
      if [ -n "$file" ] && [ -z "${seen[$file]:-}" ]; then
        seen[$file]=1
        files+=("$file")
      fi
    done < <(git -C "$repo_root" diff --name-only --cached --)
  fi

  while IFS= read -r file; do
    if [ -n "$file" ] && [ -z "${seen[$file]:-}" ]; then
      seen[$file]=1
      files+=("$file")
    fi
  done < <(git -C "$repo_root" ls-files --others --exclude-standard)

  printf '%s\n' "${files[@]}"
}

count_nonempty_lines() {
  local text="$1"
  local count=0 line

  while IFS= read -r line; do
    if [ -n "$line" ]; then
      count=$((count + 1))
    fi
  done <<<"$text"

  printf '%s\n' "$count"
}

file_size_bytes() {
  local file_path="$1"

  wc -c <"$file_path" | tr -d '[:space:]'
}

added_file_diff_for_prompt() {
  local repo_root="$1"
  local file="$2"
  local file_path file_size

  file_path="$repo_root/$file"
  file_size=$(file_size_bytes "$file_path")
  if [ "$file_size" -gt "$MAX_COMMIT_PLAN_ADDED_FILE_BYTES" ]; then
    debug_log "Omitting added file diff for '$file' because ${file_size} bytes exceeds ${MAX_COMMIT_PLAN_ADDED_FILE_BYTES}"
    printf '[Omitted added file diff for %s because its size (%s bytes) exceeds the prompt limit for added files (%s bytes).]\n' \
      "$file" "$file_size" "$MAX_COMMIT_PLAN_ADDED_FILE_BYTES"
    return 0
  fi

  git -C "$repo_root" diff --no-ext-diff --no-index /dev/null "$file" || true
}

tracked_file_diff_for_prompt() {
  local repo_root="$1"
  local file="$2"
  local has_head="$3"
  local file_diff

  if [ "$has_head" = true ]; then
    file_diff=$(git -C "$repo_root" diff --no-ext-diff HEAD -- "$file")
  else
    file_diff=$(git -C "$repo_root" diff --no-ext-diff --cached -- "$file")
  fi

  if [ "${#file_diff}" -gt "$MAX_COMMIT_PLAN_FILE_DIFF_CHARS" ]; then
    debug_log "Omitting diff for '$file' because ${#file_diff} chars exceeds ${MAX_COMMIT_PLAN_FILE_DIFF_CHARS}"
    printf '[Omitted diff for %s because its diff size (%s chars) exceeds the prompt limit per file (%s chars).]\n' \
      "$file" "${#file_diff}" "$MAX_COMMIT_PLAN_FILE_DIFF_CHARS"
    return 0
  fi

  printf '%s\n' "$file_diff"
}

file_diff_for_prompt() {
  local repo_root="$1"
  local file="$2"
  local has_head="$3"

  if git -C "$repo_root" ls-files --error-unmatch -- "$file" >/dev/null 2>&1; then
    tracked_file_diff_for_prompt "$repo_root" "$file" "$has_head"
    return 0
  fi

  added_file_diff_for_prompt "$repo_root" "$file"
}

collect_changes_diff() {
  local changed_files="$1"
  local repo_root file file_diff
  local has_head=false
  local diff_output=''

  repo_root=$(git_repo_root)

  if git rev-parse --verify HEAD >/dev/null 2>&1; then
    has_head=true
  fi

  while IFS= read -r file; do
    [ -n "$file" ] || continue
    file_diff=$(file_diff_for_prompt "$repo_root" "$file" "$has_head")
    if [ -z "$file_diff" ]; then
      continue
    fi

    if [ -n "$diff_output" ]; then
      diff_output+=$'\n'
    fi
    diff_output+="$file_diff"

    if [ "${#diff_output}" -gt "$MAX_COMMIT_PLAN_DIFF_CHARS" ]; then
      debug_log "Stopping diff collection after reaching ${MAX_COMMIT_PLAN_DIFF_CHARS} chars"
      diff_output+=$'\n[Stopped collecting additional diffs after reaching the prompt diff budget.]'
      break
    fi
  done <<<"$changed_files"

  printf '%s\n' "$diff_output"
}

truncate_commit_plan_section() {
  local section_name="$1"
  local text="$2"
  local max_chars="$3"
  local notice keep_chars

  if [ "${#text}" -le "$max_chars" ]; then
    printf '%s\n' "$text"
    return 0
  fi

  debug_log "Truncating ${section_name} from ${#text} chars to ${max_chars}"

  notice=$'\n'
  notice+="[Truncated ${section_name} to fit provider message limits.]"
  keep_chars=$((max_chars - ${#notice}))
  if [ "$keep_chars" -lt 0 ]; then
    keep_chars=0
  fi

  printf '%s%s\n' "${text:0:$keep_chars}" "$notice"
}

commit_planning_system_message() {
  cat <<'EOF'
You are an expert software engineer creating conventional commit plans.

Return JSON only with this exact shape:
{"commits":[{"type":"feat","message":"short summary","files":["path/to/file"]}]}

Rules:
- Allowed types: feat, fix, docs, refactor, chore, perf, test
- The message must be the commit subject suffix only. Do not include the type or scope prefix.
- When a scope is provided, do not repeat that scope value or its parent package/org prefix in the message unless it is required for clarity.
- Prefer one commit unless the changes clearly belong to distinct tasks.
- Prefer separate commits when reusable supporting changes are independently useful from the consuming feature.
- When one tool or shared capability is extended to support a new tool, prefer one commit for the supporting capability and another for the new consuming feature when the split is coherent.
- If you return multiple commits, each changed file must appear in exactly one commit.
- Use file paths exactly as provided.
- Do not include markdown fences or commentary.
EOF
}

build_commit_planning_message() {
  local branch="$1"
  local scope="$2"
  local changed_files="$3"
  local diff_output="$4"
  local changed_files_section diff_section

  if [ -z "$scope" ]; then
    scope='(none)'
  fi

  changed_files_section=$(truncate_commit_plan_section 'changed file list' "$changed_files" "$MAX_COMMIT_PLAN_CHANGED_FILES_CHARS")
  diff_section=$(truncate_commit_plan_section 'diff' "$diff_output" "$MAX_COMMIT_PLAN_DIFF_CHARS")

  printf '%s\n\n%s\n%s\n\n%s\n%s\n\n%s\n%s\n\n%s\n%s\n' \
    'Analyze these current git workspace changes and propose conventional commit plan JSON.' \
    'Current branch:' "$branch" \
    'Derived scope:' "$scope" \
    'Changed files:' "$changed_files_section" \
    'Unified diff:' "$diff_section"
}

request_commit_plan() {
  local profile="$1"
  local model="$2"
  local system_message="$3"
  local user_message="$4"
  local system_message_file user_message_file output status=0

  debug_log "Requesting commit plan from model-provider profile '$profile' model '$model'"
  debug_log "Prompt sizes: system=${#system_message} chars, user=${#user_message} chars"

  system_message_file=$(mktemp)
  user_message_file=$(mktemp)
  printf '%s' "$system_message" >"$system_message_file"
  printf '%s' "$user_message" >"$user_message_file"

  if output=$(run_model_provider ask "$profile" --model "$model" --system-message-file "$system_message_file" --message-file "$user_message_file"); then
    :
  else
    status=$?
  fi

  rm -f "$system_message_file" "$user_message_file"

  if [ "$status" -ne 0 ]; then
    return "$status"
  fi

  debug_log "Received commit plan response (${#output} chars)"

  printf '%s\n' "$output"
}

valid_commit_type() {
  local type="$1"
  local allowed_type

  for allowed_type in $ALLOWED_TYPES; do
    if [ "$type" = "$allowed_type" ]; then
      return 0
    fi
  done

  return 1
}

plan_commit_count() {
  local plan_json="$1"

  printf '%s' "$plan_json" | jq -r '.commits | length'
}

resolve_changed_file_reference() {
  local requested_file="$1"
  local changed_files="$2"
  local normalized_requested_file candidate_file basename_match='' suffix_match=''
  local basename_count=0
  local suffix_count=0

  normalized_requested_file="${requested_file#:/}"
  normalized_requested_file="${normalized_requested_file#./}"

  while IFS= read -r candidate_file; do
    [ -n "$candidate_file" ] || continue

    if [ "$candidate_file" = "$normalized_requested_file" ]; then
      printf '%s\n' "$candidate_file"
      return 0
    fi

    if [ "${candidate_file##*/}" = "$normalized_requested_file" ]; then
      basename_match="$candidate_file"
      basename_count=$((basename_count + 1))
    fi

    case "$candidate_file" in
    "$normalized_requested_file" | */"$normalized_requested_file")
      suffix_match="$candidate_file"
      suffix_count=$((suffix_count + 1))
      ;;
    esac
  done <<<"$changed_files"

  if [ "$basename_count" -eq 1 ]; then
    printf '%s\n' "$basename_match"
    return 0
  fi

  if [ "$suffix_count" -eq 1 ]; then
    printf '%s\n' "$suffix_match"
    return 0
  fi

  return 1
}

resolved_commit_files() {
  local plan_json="$1"
  local commit_index="$2"
  local changed_files="$3"
  local file resolved_file
  local -a commit_files=()

  mapfile -t commit_files < <(printf '%s' "$plan_json" | jq -r ".commits[$commit_index].files[]?")
  if [ "${#commit_files[@]}" -eq 0 ]; then
    echo "Error: commit plan item $((commit_index + 1)) must include files" >&2
    exit 1
  fi

  for file in "${commit_files[@]}"; do
    if ! resolved_file=$(resolve_changed_file_reference "$file" "$changed_files"); then
      echo "Error: commit plan referenced an unknown or ambiguous changed file: $file" >&2
      exit 1
    fi

    printf '%s\n' "$resolved_file"
  done
}

validate_multi_commit_plan() {
  local plan_json="$1"
  local changed_files="$2"
  local count commit_index file resolved_file
  local -A changed_file_set=()
  local -A planned_file_set=()
  local -a commit_files=()

  while IFS= read -r file; do
    if [ -n "$file" ]; then
      changed_file_set[$file]=1
    fi
  done <<<"$changed_files"

  count=$(plan_commit_count "$plan_json")
  commit_index=0
  while [ "$commit_index" -lt "$count" ]; do
    mapfile -t commit_files < <(resolved_commit_files "$plan_json" "$commit_index" "$changed_files")

    for resolved_file in "${commit_files[@]}"; do
      if [ -z "${changed_file_set[$resolved_file]:-}" ]; then
        echo "Error: commit plan referenced an unknown changed file: $resolved_file" >&2
        exit 1
      fi
      if [ -n "${planned_file_set[$resolved_file]:-}" ]; then
        echo "Error: commit plan assigned the same file to multiple commits: $resolved_file" >&2
        exit 1
      fi
      planned_file_set[$resolved_file]=1
    done

    commit_index=$((commit_index + 1))
  done

  for file in "${!changed_file_set[@]}"; do
    if [ -z "${planned_file_set[$file]:-}" ]; then
      echo "Error: commit plan did not cover changed file: $file" >&2
      exit 1
    fi
  done
}

format_commit_title() {
  local type="$1"
  local scope="$2"
  local message="$3"

  if [ -n "$scope" ]; then
    printf '%s(%s): %s\n' "$type" "$scope" "$message"
    return 0
  fi

  printf '%s: %s\n' "$type" "$message"
}

resolve_push_remote() {
  local branch="$1"
  local remote
  local -a remotes=()

  remote=$(git config --get "branch.$branch.pushRemote" 2>/dev/null || true)
  if [ -n "$remote" ]; then
    printf '%s\n' "$remote"
    return 0
  fi

  remote=$(git config --get remote.pushDefault 2>/dev/null || true)
  if [ -n "$remote" ]; then
    printf '%s\n' "$remote"
    return 0
  fi

  if git remote get-url origin >/dev/null 2>&1; then
    printf 'origin\n'
    return 0
  fi

  mapfile -t remotes < <(git remote)
  if [ "${#remotes[@]}" -eq 1 ]; then
    printf '%s\n' "${remotes[0]}"
    return 0
  fi

  echo "Error: unable to determine push remote for branch '$branch'" >&2
  exit 1
}

push_current_branch() {
  local branch="$1"
  local remote

  if git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' >/dev/null 2>&1; then
    debug_log "Pushing branch '$branch' to its configured upstream"
    git push
    return 0
  fi

  remote=$(resolve_push_remote "$branch")
  debug_log "Pushing branch '$branch' to '$remote' and setting upstream"
  git push -u "$remote" "$branch"
}

parse_run_options() {
  local scope_override=''
  local no_scope=false
  local apply_commits=false
  local push_commits=false
  local pre_commit_retries=2
  local debug_mode=false

  while [ "$#" -gt 0 ]; do
    case "$1" in
    --apply)
      apply_commits=true
      shift
      ;;
    --debug)
      debug_mode=true
      shift
      ;;
    --push)
      push_commits=true
      shift
      ;;
    --pre-commit-retries)
      if [ "$#" -lt 2 ] || [ -z "$2" ]; then
        echo 'Error: --pre-commit-retries requires a value' >&2
        exit 1
      fi
      if ! [[ "$2" =~ ^[0-9]+$ ]]; then
        echo 'Error: --pre-commit-retries must be a non-negative integer' >&2
        exit 1
      fi
      pre_commit_retries="$2"
      shift 2
      ;;
    --pre-commit-retries=*)
      pre_commit_retries="${1#--pre-commit-retries=}"
      if [ -z "$pre_commit_retries" ]; then
        echo 'Error: --pre-commit-retries requires a value' >&2
        exit 1
      fi
      if ! [[ "$pre_commit_retries" =~ ^[0-9]+$ ]]; then
        echo 'Error: --pre-commit-retries must be a non-negative integer' >&2
        exit 1
      fi
      shift
      ;;
    --scope)
      if [ "$#" -lt 2 ] || [ -z "$2" ]; then
        echo 'Error: --scope requires a value' >&2
        exit 1
      fi
      scope_override="$2"
      no_scope=false
      shift 2
      ;;
    --scope=*)
      scope_override="${1#--scope=}"
      if [ -z "$scope_override" ]; then
        echo 'Error: --scope requires a value' >&2
        exit 1
      fi
      no_scope=false
      shift
      ;;
    --no-scope)
      scope_override=''
      no_scope=true
      shift
      ;;
    *)
      echo "Error: unknown option '$1'" >&2
      usage >&2
      exit 1
      ;;
    esac
  done

  if [ "$push_commits" = 'true' ] && [ "$apply_commits" != 'true' ]; then
    echo 'Error: --push requires --apply' >&2
    exit 1
  fi

  printf '%s\n%s\n%s\n%s\n%s\n%s\n' "$scope_override" "$no_scope" "$apply_commits" "$push_commits" "$pre_commit_retries" "$debug_mode"
}

resolve_scope() {
  local branch="$1"
  local scope_override="$2"
  local no_scope="$3"
  local changed_files="$4"
  local scope

  if [ "$no_scope" = 'true' ]; then
    printf '\n'
    return 0
  fi

  if [ -n "$scope_override" ]; then
    printf '%s\n' "$scope_override"
    return 0
  fi

  scope=$(derive_scope_from_branch "$branch")
  if [ -n "$scope" ]; then
    printf '%s\n' "$scope"
    return 0
  fi

  derive_scope_from_monorepo "$changed_files"
}

print_git_add_command() {
  if [ "$#" -eq 0 ]; then
    echo 'git add -A :/'
    return 0
  fi

  local file
  printf 'git add --'
  for file in "$@"; do
    printf ' %q' ":/$file"
  done
  printf '\n'
}

print_git_commit_command() {
  local title="$1"
  local escaped_title

  escaped_title=${title//\\/\\\\}
  escaped_title=${escaped_title//"/\\"/}
  printf 'git commit -m "%s"\n' "$escaped_title"
}

print_commit_plan() {
  local plan_json="$1"
  local scope="$2"
  local changed_files="$3"
  local count commit_index type message title
  local -a commit_files=()

  count=$(plan_commit_count "$plan_json")
  if [ "$count" -gt 1 ]; then
    validate_multi_commit_plan "$plan_json" "$changed_files"
  fi

  commit_index=0
  while [ "$commit_index" -lt "$count" ]; do
    type=$(printf '%s' "$plan_json" | jq -r ".commits[$commit_index].type // empty")
    message=$(printf '%s' "$plan_json" | jq -r ".commits[$commit_index].message // empty")

    if ! valid_commit_type "$type"; then
      echo "Error: invalid commit type in plan: $type" >&2
      exit 1
    fi

    if [ -z "$message" ]; then
      echo "Error: commit plan item $((commit_index + 1)) is missing a message" >&2
      exit 1
    fi

    title=$(format_commit_title "$type" "$scope" "$message")

    if [ "$count" -eq 1 ]; then
      print_git_add_command
    else
      mapfile -t commit_files < <(resolved_commit_files "$plan_json" "$commit_index" "$changed_files")
      printf 'Commit %d:\n' "$((commit_index + 1))"
      print_git_add_command "${commit_files[@]}"
    fi

    print_git_commit_command "$title"
    if [ "$commit_index" -lt $((count - 1)) ]; then
      printf '\n'
    fi
    commit_index=$((commit_index + 1))
  done
}

execute_commit_plan() {
  local plan_json="$1"
  local scope="$2"
  local changed_files="$3"
  local count commit_index type message title
  local -a commit_files=()

  count=$(plan_commit_count "$plan_json")
  debug_log "Applying commit plan with $count commit(s)"
  if [ "$count" -gt 1 ]; then
    validate_multi_commit_plan "$plan_json" "$changed_files"
  fi

  commit_index=0
  while [ "$commit_index" -lt "$count" ]; do
    type=$(printf '%s' "$plan_json" | jq -r ".commits[$commit_index].type // empty")
    message=$(printf '%s' "$plan_json" | jq -r ".commits[$commit_index].message // empty")

    if ! valid_commit_type "$type"; then
      echo "Error: invalid commit type in plan: $type" >&2
      exit 1
    fi

    if [ -z "$message" ]; then
      echo "Error: commit plan item $((commit_index + 1)) is missing a message" >&2
      exit 1
    fi

    title=$(format_commit_title "$type" "$scope" "$message")
    debug_log "Creating commit $((commit_index + 1))/$count: $title"

    if [ "$count" -eq 1 ]; then
      git add -A :/
    else
      mapfile -t commit_files < <(resolved_commit_files "$plan_json" "$commit_index" "$changed_files")
      git add -- "${commit_files[@]/#/:/}"
    fi

    git commit -m "$title"
    commit_index=$((commit_index + 1))
  done
}

run_commit_tool() {
  local config_values profile model branch scope changed_files diff_output system_message user_message plan_json scope_override no_scope apply_commits push_commits pre_commit_retries debug_mode changed_file_count
  local -a option_values=()

  mapfile -t option_values < <(parse_run_options "$@")
  scope_override="${option_values[0]:-}"
  no_scope="${option_values[1]:-false}"
  apply_commits="${option_values[2]:-false}"
  push_commits="${option_values[3]:-false}"
  pre_commit_retries="${option_values[4]:-2}"
  debug_mode="${option_values[5]:-false}"

  if [ "$debug_mode" = 'true' ]; then
    enable_debug_logging
  fi

  debug_log 'Checking repository state'
  require_git_repository
  ensure_no_staged_changes
  ensure_changes_exist

  debug_log 'Collecting changed files'
  changed_files=$(collect_changed_files)
  changed_file_count=$(count_nonempty_lines "$changed_files")
  debug_log "Collected $changed_file_count changed file(s)"

  run_pre_commit_checks "$changed_files" "$pre_commit_retries"
  ensure_changes_exist

  debug_log 'Refreshing changed files after pre-commit checks'
  changed_files=$(collect_changed_files)
  changed_file_count=$(count_nonempty_lines "$changed_files")
  debug_log "Collected $changed_file_count changed file(s) after pre-commit"

  debug_log 'Loading configured model provider'
  config_values=$(load_configuration)
  IFS=$'\t' read -r profile model <<<"$config_values"
  require_dependencies

  debug_log 'Resolving branch and commit scope'
  branch=$(current_branch_name)
  scope=$(resolve_scope "$branch" "$scope_override" "$no_scope" "$changed_files")
  debug_log "Resolved branch '$branch' and scope '${scope:-<none>}'"

  debug_log 'Collecting workspace diff for commit planning'
  diff_output=$(collect_changes_diff "$changed_files")
  system_message=$(commit_planning_system_message)
  user_message=$(build_commit_planning_message "$branch" "$scope" "$changed_files" "$diff_output")
  plan_json=$(request_commit_plan "$profile" "$model" "$system_message" "$user_message")

  if ! printf '%s' "$plan_json" | jq -e '.commits | type == "array"' >/dev/null 2>&1; then
    echo 'Error: model-provider ask did not return valid commit plan JSON' >&2
    exit 1
  fi

  debug_log 'Validated commit plan JSON'

  if [ "$apply_commits" = 'true' ]; then
    execute_commit_plan "$plan_json" "$scope" "$changed_files"
    if [ "$push_commits" = 'true' ]; then
      debug_log 'Pushing committed branch'
      push_current_branch "$branch"
    fi
    return 0
  fi

  debug_log 'Printing commit plan preview'
  print_commit_plan "$plan_json" "$scope" "$changed_files"
}

main() {
  case "${1:-}" in
  -h | --help | help)
    usage
    exit 0
    ;;
  -v | --version | version)
    print_version
    exit 0
    ;;
  configure)
    shift
    configure_tool "$@"
    ;;
  '' | --debug | --apply | --push | --pre-commit-retries | --pre-commit-retries=* | --scope | --scope=* | --no-scope)
    run_commit_tool "$@"
    ;;
  *)
    echo "Error: unknown command '$1'" >&2
    usage >&2
    exit 1
    ;;
  esac
}

main "$@"
