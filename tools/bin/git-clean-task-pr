#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOAD_SH="${SCRIPT_DIR}/../lib/picotools/load.sh"
if [ ! -f "$LOAD_SH" ]; then
  LOAD_SH="${SCRIPT_DIR}/../../lib/picotools/load.sh"
fi
# shellcheck source=../../lib/picotools/load.sh
# shellcheck disable=SC1091
. "$LOAD_SH"
picotools_source_modules "$SCRIPT_DIR" commands git version

usage() {
  cat <<'EOF'
Usage: git-clean-task-pr [options] [base-branch]

Creates a new branch from the current branch, pulls the base branch into it,
and then soft-resets to origin/<base-branch> so your branch changes are staged
as one clean commit.

If no branch name is provided, the script prompts with a suggested name based
on the current branch:
  feat/1234      -> feat/1234-1
  feat/1234-1    -> feat/1234-2

Options:
  -b, --branch NAME         New branch name to create
  -r, --remote REMOTE       Remote name (default: origin)
  -m, --temp-message MSG    Temporary commit message for --continue
                            (default: chore(0000): temporary message)
  --continue                Resume after resolving merge conflicts
  --debug                   Print progress details to stderr
  -h, --help, help          Show this help message
  -v, --version, version    Show the tool version

Arguments:
  base-branch               Base branch to reset against
                            (default: remote default branch)
EOF
}

print_version() {
  picotools_print_version "$SCRIPT_DIR"
}

debug_mode=false

debug_enabled() {
  [ "$debug_mode" = 'true' ]
}

debug_log() {
  if debug_enabled; then
    printf '[git-clean-task-pr] %s\n' "$1" >&2
  fi
}

ensure_clean_worktree() {
  local status

  status=$(git status --porcelain)
  if [ -n "$status" ]; then
    echo "Error: working tree must be clean before starting" >&2
    exit 1
  fi
}

derive_branch_name() {
  local current_branch="$1"

  if [[ "$current_branch" =~ ^(.*)_([0-9]+)$ ]]; then
    printf '%s_%d\n' "${BASH_REMATCH[1]}" "$((10#${BASH_REMATCH[2]} + 1))"
    return 0
  fi

  printf '%s_1\n' "$current_branch"
}

prompt_branch_name() {
  local suggested="$1"
  local answer=""

  printf 'New branch name [%s]: ' "$suggested" >&2
  read -r answer || true

  if [ -n "$answer" ]; then
    printf '%s\n' "$answer"
    return 0
  fi

  printf '%s\n' "$suggested"
}

ensure_branch_available() {
  local branch_name="$1"

  if git show-ref --verify --quiet "refs/heads/${branch_name}"; then
    echo "Error: local branch '${branch_name}' already exists" >&2
    exit 1
  fi
}

ensure_base_branch_exists() {
  local remote="$1"
  local base_branch="$2"

  if ! git rev-parse --verify --quiet "refs/remotes/${remote}/${base_branch}" >/dev/null; then
    echo "Error: remote branch '${remote}/${base_branch}' does not exist" >&2
    exit 1
  fi
}

continue_after_conflicts() {
  local remote="$1"
  local base_branch="$2"
  local temp_message="$3"
  local merge_head
  local unresolved_files

  merge_head=$(git rev-parse --git-path MERGE_HEAD)
  if [ ! -f "$merge_head" ]; then
    echo "Error: no merge is in progress" >&2
    exit 1
  fi

  unresolved_files=$(git diff --name-only --diff-filter=U)
  if [ -n "$unresolved_files" ]; then
    echo "Error: merge conflicts are still unresolved" >&2
    printf '%s\n' "$unresolved_files" >&2
    exit 1
  fi

  debug_log "Fetching '$remote/$base_branch' before continuing"
  git fetch "$remote" "$base_branch"
  ensure_base_branch_exists "$remote" "$base_branch"

  debug_log "Creating temporary merge-resolution commit '$temp_message'"
  git commit -m "$temp_message"
  debug_log "Soft-resetting to '${remote}/${base_branch}'"
  git reset --soft "${remote}/${base_branch}"

  echo "Soft reset complete. Create your final commit when ready."
}

main() {
  local remote=origin
  local base_branch=""
  local new_branch=""
  local temp_message="chore(0000): temporary message"
  local continue_mode=false
  local current_branch
  local suggested_branch
  local merge_head

  while [ $# -gt 0 ]; do
    case "$1" in
    -b | --branch)
      if [ $# -lt 2 ]; then
        echo "Error: missing value for $1" >&2
        exit 1
      fi
      new_branch="$2"
      shift 2
      ;;
    -r | --remote)
      if [ $# -lt 2 ]; then
        echo "Error: missing value for $1" >&2
        exit 1
      fi
      remote="$2"
      shift 2
      ;;
    -m | --temp-message)
      if [ $# -lt 2 ]; then
        echo "Error: missing value for $1" >&2
        exit 1
      fi
      temp_message="$2"
      shift 2
      ;;
    --continue)
      continue_mode=true
      shift
      ;;
    --debug)
      debug_mode=true
      shift
      ;;
    -h | --help | help)
      usage
      exit 0
      ;;
    -v | --version | version)
      print_version
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "Error: unexpected option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [ -n "$base_branch" ]; then
        echo "Error: unexpected argument: $1" >&2
        usage >&2
        exit 1
      fi
      base_branch="$1"
      shift
      ;;
    esac
  done

  if [ $# -gt 0 ]; then
    echo "Error: unexpected argument: $1" >&2
    usage >&2
    exit 1
  fi

  picotools_require_git_repo

  if ! git remote get-url "$remote" >/dev/null 2>&1; then
    echo "Error: remote '${remote}' does not exist" >&2
    exit 1
  fi

  if [ -z "$base_branch" ]; then
    base_branch=$(picotools_git_default_branch "$remote")
    if [ -z "$base_branch" ]; then
      echo "Error: could not determine the default branch for remote '${remote}' from local refs" >&2
      echo "Pass the base branch explicitly or update the local remote HEAD with: git remote set-head ${remote} --auto" >&2
      exit 1
    fi
  fi

  if [ "$continue_mode" = true ]; then
    debug_log "Continuing cleanup branch flow for '$remote/$base_branch'"
    continue_after_conflicts "$remote" "$base_branch" "$temp_message"
    exit 0
  fi

  ensure_clean_worktree

  current_branch=$(git branch --show-current)
  if [ -z "$current_branch" ]; then
    echo "Error: detached HEAD is not supported" >&2
    exit 1
  fi

  if [ -z "$new_branch" ]; then
    suggested_branch=$(derive_branch_name "$current_branch")
    if [ -t 0 ]; then
      new_branch=$(prompt_branch_name "$suggested_branch")
    else
      new_branch="$suggested_branch"
    fi
  fi

  if [ -z "$new_branch" ]; then
    echo "Error: branch name cannot be empty" >&2
    exit 1
  fi

  if [ "$new_branch" = "$current_branch" ]; then
    echo "Error: new branch name must differ from the current branch" >&2
    exit 1
  fi

  debug_log "Creating cleanup branch '$new_branch' from '$current_branch' against '$remote/$base_branch'"
  ensure_branch_available "$new_branch"

  debug_log "Fetching '$remote/$base_branch'"
  git fetch "$remote" "$base_branch"
  ensure_base_branch_exists "$remote" "$base_branch"

  debug_log "Checking out new branch '$new_branch'"
  git checkout -b "$new_branch"

  debug_log "Pulling '$remote/$base_branch' into '$new_branch'"
  if git pull "$remote" "$base_branch" --no-rebase --no-edit; then
    debug_log "Soft-resetting '$new_branch' to '${remote}/${base_branch}'"
    git reset --soft "${remote}/${base_branch}"
    echo "Soft reset complete. Create your final commit when ready."
    exit 0
  fi

  merge_head=$(git rev-parse --git-path MERGE_HEAD)
  if [ -f "$merge_head" ]; then
    echo "Merge conflicts need to be resolved on branch '${new_branch}'." >&2
    echo "Resolve them, stage the files, then run:" >&2
    printf '  git-clean-task-pr --continue --remote %q %q\n' "$remote" "$base_branch" >&2
    exit 1
  fi

  echo "Error: failed to pull '${remote}/${base_branch}'" >&2
  exit 1
}

main "$@"
