#!/usr/bin/env bash
set -eo pipefail

tool_name="picotools"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOAD_SH="${SCRIPT_DIR}/../lib/picotools/load.sh"
if [ ! -f "$LOAD_SH" ]; then
  LOAD_SH="${SCRIPT_DIR}/../../lib/picotools/load.sh"
fi
# shellcheck source=../lib/picotools/load.sh
# shellcheck disable=SC1091
. "$LOAD_SH"
picotools_source_modules "$SCRIPT_DIR" github

github_coordinates="${ASDF_PICOTOOLS_GITHUB_REPOSITORY:-$(picotools_resolve_github_coordinates "$SCRIPT_DIR")}"
base_download_url="https://github.com/${github_coordinates}/releases/download"

version="$ASDF_INSTALL_VERSION"
download_path="$ASDF_DOWNLOAD_PATH"

filename="${tool_name}-${version}.tar.gz"

mkdir -p "$download_path"
download_url="${base_download_url}/v${version}/${filename}"
outfile="${download_path}/${filename}"

echo "Attempting to download: $download_url"

if curl -L --fail --connect-timeout 10 --retry 3 "${download_url}" -o "${outfile}"; then
  echo "Download successful."
  exit 0
else
  echo "Error: Failed to download ${filename} for v${version}."
  exit 1
fi
