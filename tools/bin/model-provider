#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOAD_SH="${SCRIPT_DIR}/../lib/picotools/load.sh"
if [ ! -f "$LOAD_SH" ]; then
  LOAD_SH="${SCRIPT_DIR}/../../lib/picotools/load.sh"
fi
# shellcheck source=../../lib/picotools/load.sh
# shellcheck disable=SC1091
. "$LOAD_SH"
picotools_source_modules "$SCRIPT_DIR" prompt table version

usage() {
  cat <<'EOF'
Usage: model-provider <command>

Commands:
  create    Create a saved model provider profile
  update    Update a saved model provider profile
  list      List saved model provider profiles
  read      Show detailed information for a saved model provider profile
  profiles  List saved model provider profile names
  models    List configured models for a profile
  ask       Send a prompt to a model provider profile
  delete    Delete a saved model provider profile

Options:
  -h, --help, help          Show this help message
  -v, --version, version    Show the tool version

Ask:
  model-provider ask
  model-provider ask <profile> --message TEXT [--model MODEL] [--system-message TEXT]
  model-provider ask <profile> --user-message TEXT [--model MODEL] [--system-message TEXT]
  model-provider ask <profile> --message-file PATH [--model MODEL] [--system-message-file PATH]
EOF
}

print_version() {
  picotools_print_version "$SCRIPT_DIR"
}

config_dir() {
  printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}/model-provider"
}

data_dir() {
  printf '%s\n' "${XDG_DATA_HOME:-$HOME/.local/share}/model-provider"
}

ensure_storage_dirs() {
  mkdir -p "$(config_dir)" "$(data_dir)"
}

validate_profile_name() {
  local name="$1"

  if [[ ! "$name" =~ ^[A-Za-z0-9._-]+([[:space:]][A-Za-z0-9._-]+)*$ ]]; then
    echo "Error: profile name may contain letters, numbers, spaces, dots, underscores, and hyphens" >&2
    exit 1
  fi
}

validate_provider_type() {
  local provider_type="$1"

  case "$provider_type" in
  azure-openai | azure-cognitive-services | gemini | custom) ;;
  *)
    echo "Error: provider type must be one of azure-openai, azure-cognitive-services, gemini, custom" >&2
    exit 1
    ;;
  esac
}

provider_type_label() {
  local provider_type="$1"

  case "$provider_type" in
  azure-openai)
    printf '%s\n' 'Azure OpenAI'
    ;;
  azure-cognitive-services)
    printf '%s\n' 'Azure Cognitive Services'
    ;;
  gemini)
    printf '%s\n' 'Gemini'
    ;;
  custom)
    printf '%s\n' 'Custom'
    ;;
  *)
    printf '%s\n' "$provider_type"
    ;;
  esac
}

provider_type_from_selection() {
  local selection="$1"

  case "$selection" in
  1)
    printf '%s\n' 'azure-openai'
    ;;
  2)
    printf '%s\n' 'azure-cognitive-services'
    ;;
  3)
    printf '%s\n' 'gemini'
    ;;
  4)
    printf '%s\n' 'custom'
    ;;
  *)
    return 1
    ;;
  esac
}

provider_type_default_selection() {
  local provider_type="${1:-}"

  case "$provider_type" in
  azure-openai)
    printf '%s\n' '1'
    ;;
  azure-cognitive-services)
    printf '%s\n' '2'
    ;;
  gemini)
    printf '%s\n' '3'
    ;;
  custom)
    printf '%s\n' '4'
    ;;
  *)
    printf '%s\n' '1'
    ;;
  esac
}

profile_file() {
  local name="$1"
  printf '%s/%s.conf\n' "$(config_dir)" "$name"
}

token_file() {
  local name="$1"
  printf '%s/%s.token\n' "$(data_dir)" "$name"
}

saved_profile_files() {
  local dir

  dir=$(config_dir)
  if [ ! -d "$dir" ] || ! compgen -G "$dir/*.conf" >/dev/null; then
    return 1
  fi

  printf '%s\n' "$dir"/*.conf | sort
}

profile_name_from_file() {
  local file="$1"
  basename "$file" .conf
}

write_profile_value() {
  local file="$1"
  local key="$2"
  local value="$3"

  git config -f "$file" "$key" "$value"
}

unset_profile_value() {
  local file="$1"
  local key="$2"

  git config -f "$file" --unset-all "$key" 2>/dev/null || true
}

read_profile_value() {
  local file="$1"
  local key="$2"

  git config -f "$file" --get "$key"
}

read_profile_value_optional() {
  local file="$1"
  local key="$2"

  git config -f "$file" --get "$key" 2>/dev/null || true
}

display_value() {
  local value="${1:-}"

  if [ -n "$value" ]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' '-'
  fi
}

normalize_models_value() {
  local value="$1"
  local -a parts=()
  local -a normalized_parts=()
  local part normalized_part joined=''

  IFS=',' read -r -a parts <<<"$value"

  for part in "${parts[@]}"; do
    normalized_part=${part#"${part%%[![:space:]]*}"}
    normalized_part=${normalized_part%"${normalized_part##*[![:space:]]}"}

    if [ -n "$normalized_part" ]; then
      normalized_parts+=("$normalized_part")
    fi
  done

  for part in "${normalized_parts[@]}"; do
    if [ -n "$joined" ]; then
      joined+=','
    fi
    joined+="$part"
  done

  printf '%s\n' "$joined"
}

provider_models_value() {
  local file="$1"
  read_profile_value_optional "$file" provider.models
}

provider_resource_name_value() {
  local file="$1"
  read_profile_value_optional "$file" provider.resourceName
}

provider_endpoint_url_value() {
  local file="$1"
  read_profile_value_optional "$file" provider.endpointUrl
}

provider_has_resource_name() {
  local provider_type="$1"

  case "$provider_type" in
  azure-openai | azure-cognitive-services)
    return 0
    ;;
  esac

  return 1
}

provider_has_endpoint_url() {
  local provider_type="$1"

  case "$provider_type" in
  custom)
    return 0
    ;;
  esac

  return 1
}

normalize_endpoint_url_value() {
  local value="$1"

  value=${value#"${value%%[![:space:]]*}"}
  value=${value%"${value##*[![:space:]]}"}

  if [ -n "$value" ] && [[ "$value" != */ ]]; then
    value+='/'
  fi

  printf '%s\n' "$value"
}

provider_endpoint() {
  local provider_type="$1"
  local resource_name="$2"
  local endpoint_url="${3:-}"

  case "$provider_type" in
  azure-openai)
    if [ -z "$resource_name" ]; then
      return 0
    fi
    printf 'https://%s.openai.azure.com/\n' "$resource_name"
    ;;
  azure-cognitive-services)
    if [ -z "$resource_name" ]; then
      return 0
    fi
    printf 'https://%s.cognitiveservices.azure.com/\n' "$resource_name"
    ;;
  custom)
    printf '%s\n' "$endpoint_url"
    ;;
  esac
}

provider_openai_base_url() {
  local provider_type="$1"
  local resource_name="$2"
  local endpoint_url="${3:-}"

  case "$provider_type" in
  azure-openai)
    printf 'https://%s.openai.azure.com/openai/v1/\n' "$resource_name"
    ;;
  azure-cognitive-services)
    printf 'https://%s.cognitiveservices.azure.com/openai/v1/\n' "$resource_name"
    ;;
  gemini)
    printf '%s\n' 'https://generativelanguage.googleapis.com/v1beta/openai/'
    ;;
  custom)
    printf '%s\n' "$endpoint_url"
    ;;
  *)
    echo "Error: unsupported provider type '$provider_type'" >&2
    exit 1
    ;;
  esac
}

read_token() {
  local name="$1"
  local file

  file=$(token_file "$name")
  if [ ! -f "$file" ]; then
    echo "Error: API key not found for profile '$name'" >&2
    exit 1
  fi

  tr -d '\r\n' <"$file"
}

require_existing_profile_file() {
  local name="$1"
  local file

  file=$(profile_file "$name")
  if [ ! -f "$file" ]; then
    echo "Error: profile not found: $name" >&2
    exit 1
  fi

  printf '%s\n' "$file"
}

require_ask_tools() {
  local tool

  for tool in curl jq; do
    if ! command -v "$tool" >/dev/null 2>&1; then
      echo "Error: required tool not found: $tool" >&2
      exit 1
    fi
  done
}

select_profile_model() {
  local file="$1"
  local selection
  local model_list
  local -a model_items=()

  model_list=$(provider_models_value "$file")
  IFS=',' read -r -a model_items <<<"$model_list"

  if [ "${#model_items[@]}" -eq 0 ]; then
    echo 'Error: no models configured for the selected profile' >&2
    exit 1
  fi

  if ! selection=$(prompt_select_index 'Models' 'Select model' 1 false "${model_items[@]}"); then
    return 1
  fi

  printf '%s\n' "${model_items[$((selection - 1))]}"
}

default_profile_model() {
  local file="$1"
  local model_list
  local -a model_items=()

  model_list=$(provider_models_value "$file")
  IFS=',' read -r -a model_items <<<"$model_list"

  if [ "${#model_items[@]}" -eq 0 ] || [ -z "${model_items[0]}" ]; then
    echo 'Error: no models configured for the selected profile' >&2
    exit 1
  fi

  printf '%s\n' "${model_items[0]}"
}

profile_has_model() {
  local file="$1"
  local requested_model="$2"
  local model_list
  local model_item
  local -a model_items=()

  model_list=$(provider_models_value "$file")
  IFS=',' read -r -a model_items <<<"$model_list"

  for model_item in "${model_items[@]}"; do
    if [ "$model_item" = "$requested_model" ]; then
      return 0
    fi
  done

  return 1
}

provider_chat_completion() {
  local file="$1"
  local model="$2"
  local system_message="$3"
  local user_message="$4"
  local name provider_type resource_name endpoint_url base_url token payload_file tmpfile system_message_file user_message_file http_code response_text error_message

  name=$(profile_name_from_file "$file")
  provider_type=$(read_profile_value "$file" provider.type)
  resource_name=$(provider_resource_name_value "$file")
  endpoint_url=$(provider_endpoint_url_value "$file")
  base_url=$(provider_openai_base_url "$provider_type" "$resource_name" "$endpoint_url")
  token=$(read_token "$name")
  payload_file=$(mktemp)
  system_message_file=$(mktemp)
  user_message_file=$(mktemp)
  printf '%s' "$system_message" >"$system_message_file"
  printf '%s' "$user_message" >"$user_message_file"
  jq -n \
    --arg model "$model" \
    --rawfile system_message "$system_message_file" \
    --rawfile user_message "$user_message_file" \
    '{model: $model, messages: [{role: "system", content: $system_message}, {role: "user", content: $user_message}]}' >"$payload_file"
  rm -f "$system_message_file" "$user_message_file"
  tmpfile=$(mktemp)

  http_code=$(curl -sS -o "$tmpfile" -w '%{http_code}' \
    -H 'Content-Type: application/json' \
    -H "Authorization: Bearer $token" \
    --data-binary "@$payload_file" \
    "${base_url}chat/completions") || {
    rm -f "$system_message_file"
    rm -f "$user_message_file"
    rm -f "$payload_file"
    rm -f "$tmpfile"
    exit 1
  }

  rm -f "$payload_file"

  if [[ "$http_code" != 2* ]]; then
    error_message=$(jq -r '.error.message // .message // empty' <"$tmpfile" 2>/dev/null || true)
    rm -f "$tmpfile"
    if [ -n "$error_message" ]; then
      echo "Error: $error_message" >&2
    else
      echo "Error: request failed with HTTP $http_code" >&2
    fi
    exit 1
  fi

  response_text=$(jq -r '.choices[0].message.content // empty' <"$tmpfile")
  rm -f "$tmpfile"

  if [ -z "$response_text" ]; then
    echo 'Error: response did not contain message content' >&2
    exit 1
  fi

  printf '%s\n' "$response_text"
}

token_exists() {
  local name="$1"

  [ -f "$(token_file "$name")" ]
}

write_token() {
  local name="$1"
  local token="$2"
  local file

  file=$(token_file "$name")
  mkdir -p "$(dirname "$file")"
  umask 077
  printf '%s\n' "$token" >"$file"
}

delete_token() {
  local name="$1"
  rm -f "$(token_file "$name")"
}

prompt_value() {
  picotools_prompt_value "$@"
}

prompt_yes_no() {
  picotools_prompt_yes_no "$@"
}

prompt_select_index() {
  picotools_prompt_select_index "$@"
}

prompt_provider_type() {
  local current_value="${1:-}"
  local selection default_selection provider_type
  local -a labels=(
    'Azure OpenAI'
    'Azure Cognitive Services'
    'Gemini'
    'Custom'
  )

  default_selection=$(provider_type_default_selection "$current_value")

  while true; do
    if selection=$(prompt_select_index 'Provider types' 'Select provider type' "$default_selection" false "${labels[@]}"); then
      :
    else
      if [ "$?" -eq 2 ]; then
        return 1
      fi

      echo 'Please choose 1, 2, 3, or 4.' >&2
      continue
    fi

    if provider_type=$(provider_type_from_selection "$selection"); then
      printf '%s\n' "$provider_type"
      return 0
    fi

    echo 'Please choose 1, 2, 3, or 4.' >&2
  done
}

prompt_profile_fields() {
  local provider_type="$1"
  local current_resource_name="${2:-}"
  local current_endpoint_url="${3:-}"
  local current_models="${4:-}"
  local resource_name='' endpoint_url='' models=''

  if provider_has_resource_name "$provider_type"; then
    resource_name=$(prompt_value 'Resource name' "$current_resource_name" true)
  fi

  if provider_has_endpoint_url "$provider_type"; then
    endpoint_url=$(prompt_value 'Endpoint URL' "$current_endpoint_url" true)
    endpoint_url=$(normalize_endpoint_url_value "$endpoint_url")
  fi

  models=$(prompt_value 'Models (comma-separated)' "$current_models" true)
  models=$(normalize_models_value "$models")

  printf '%s\001%s\001%s\n' "$resource_name" "$endpoint_url" "$models"
}

save_profile() {
  local file="$1"
  local provider_type="$2"
  local resource_name="$3"
  local endpoint_url="$4"
  local models="$5"

  rm -f "$file"
  write_profile_value "$file" provider.type "$provider_type"

  if [ -n "$resource_name" ]; then
    write_profile_value "$file" provider.resourceName "$resource_name"
  fi

  if [ -n "$endpoint_url" ]; then
    write_profile_value "$file" provider.endpointUrl "$endpoint_url"
  fi

  if [ -n "$models" ]; then
    write_profile_value "$file" provider.models "$models"
  fi
}

select_profile_file() {
  local selection file name
  local files=()
  local names=()

  if ! saved_profile_files >/dev/null; then
    echo 'No model provider profiles found.' >&2
    exit 1
  fi

  while IFS= read -r file; do
    files+=("$file")
    name=$(profile_name_from_file "$file")
    names+=("$name")
  done < <(saved_profile_files)

  if ! selection=$(prompt_select_index 'Profiles' 'Select profile' '' false "${names[@]}"); then
    return 1
  fi

  printf '%s\n' "${files[$((selection - 1))]}"
}

format_profile_summary_row() {
  local file="$1"
  local index="$2"
  local name provider_type resource_name endpoint_url location models token_status

  name=$(profile_name_from_file "$file")
  provider_type=$(read_profile_value "$file" provider.type)
  resource_name=$(provider_resource_name_value "$file")
  endpoint_url=$(provider_endpoint_url_value "$file")
  location="$resource_name"
  if [ -z "$location" ]; then
    location="$endpoint_url"
  fi
  models=$(provider_models_value "$file")

  if token_exists "$name"; then
    token_status=yes
  else
    token_status=no
  fi

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$index" \
    "$name" \
    "$(provider_type_label "$provider_type")" \
    "$(display_value "$location")" \
    "$(display_value "$models")" \
    "$token_status"
}

print_profile_detail() {
  local file="$1"
  local name provider_type resource_name endpoint_url endpoint models token_status token_path

  name=$(profile_name_from_file "$file")
  provider_type=$(read_profile_value "$file" provider.type)
  resource_name=$(provider_resource_name_value "$file")
  endpoint_url=$(provider_endpoint_url_value "$file")
  endpoint=$(provider_endpoint "$provider_type" "$resource_name" "$endpoint_url")
  models=$(provider_models_value "$file")
  token_path=$(token_file "$name")

  if token_exists "$name"; then
    token_status=yes
  else
    token_status=no
  fi

  picotools_print_two_column_table \
    $'Name	'"$name" \
    $'Type	'"$(provider_type_label "$provider_type")" \
    $'Resource Name	'"$(display_value "$resource_name")" \
    $'Endpoint URL	'"$(display_value "$endpoint_url")" \
    $'Endpoint	'"$(display_value "$endpoint")" \
    $'Models	'"$(display_value "$models")" \
    $'Token Stored	'"$token_status" \
    $'Config File	'"$file" \
    $'Token File	'"$token_path"
}

create_profile() {
  local name file overwrite provider_type token resource_name endpoint_url models selected_fields

  name=$(prompt_value 'Profile name' '' true)
  validate_profile_name "$name"
  ensure_storage_dirs
  file=$(profile_file "$name")

  if [ -f "$file" ]; then
    overwrite=$(prompt_yes_no "Profile '$name' already exists. Overwrite?" no)
    if [ "$overwrite" != 'yes' ]; then
      echo 'Cancelled.' >&2
      exit 1
    fi
  fi

  if ! provider_type=$(prompt_provider_type); then
    echo 'Cancelled.' >&2
    exit 1
  fi
  selected_fields=$(prompt_profile_fields "$provider_type")
  IFS=$'\001' read -r resource_name endpoint_url models <<<"$selected_fields"
  token=$(prompt_value 'API key' '' true)

  save_profile "$file" "$provider_type" "$resource_name" "$endpoint_url" "$models"
  write_token "$name" "$token"
  echo "Saved model provider profile '$name'."
}

list_profiles() {
  local file
  local index=1
  local -a rows=()

  if ! saved_profile_files >/dev/null; then
    echo 'No model provider profiles found.'
    return 0
  fi

  while IFS= read -r file; do
    rows+=("$(format_profile_summary_row "$file" "$index")")
    index=$((index + 1))
  done < <(saved_profile_files)

  picotools_print_table $'#	Name	Type	Resource	Models	Token' "${rows[@]}"
}

read_profile() {
  local file

  if ! file=$(select_profile_file); then
    return 0
  fi
  print_profile_detail "$file"
}

list_profile_names() {
  local file

  if ! saved_profile_files >/dev/null; then
    return 0
  fi

  while IFS= read -r file; do
    profile_name_from_file "$file"
  done < <(saved_profile_files)
}

list_profile_models() {
  local profile_name="${1:-}"
  local file model_list
  local model_item
  local -a model_items=()

  if [ -z "$profile_name" ]; then
    echo 'Error: models requires a profile name' >&2
    exit 1
  fi

  file=$(require_existing_profile_file "$profile_name")
  model_list=$(provider_models_value "$file")
  IFS=',' read -r -a model_items <<<"$model_list"

  for model_item in "${model_items[@]}"; do
    printf '%s\n' "$model_item"
  done
}

update_profile_file() {
  local file="$1"
  local name provider_type resource_name endpoint_url models selected_fields
  local update_token token

  name=$(profile_name_from_file "$file")
  provider_type=$(read_profile_value "$file" provider.type)
  resource_name=$(provider_resource_name_value "$file")
  endpoint_url=$(provider_endpoint_url_value "$file")
  models=$(provider_models_value "$file")

  if ! provider_type=$(prompt_provider_type "$provider_type"); then
    echo 'Cancelled.' >&2
    exit 1
  fi
  selected_fields=$(prompt_profile_fields "$provider_type" "$resource_name" "$endpoint_url" "$models")
  IFS=$'\001' read -r resource_name endpoint_url models <<<"$selected_fields"

  save_profile "$file" "$provider_type" "$resource_name" "$endpoint_url" "$models"

  update_token=$(prompt_yes_no 'Update API key?' no)
  if [ "$update_token" = 'yes' ]; then
    token=$(prompt_value 'API key' '' true)
    write_token "$name" "$token"
  fi

  echo "Updated model provider profile '$name'."
}

delete_profile_file() {
  local file="$1"
  local name confirm

  name=$(profile_name_from_file "$file")
  confirm=$(prompt_yes_no "Delete '$name'?" no)
  if [ "$confirm" != 'yes' ]; then
    echo 'Cancelled.' >&2
    exit 1
  fi

  rm -f "$file"
  delete_token "$name"
  echo 'Deleted model provider profile.'
}

update_profile() {
  local file

  if ! file=$(select_profile_file); then
    return 0
  fi
  update_profile_file "$file"
}

delete_profile() {
  local file

  if ! file=$(select_profile_file); then
    return 0
  fi
  delete_profile_file "$file"
}

ask_provider_interactive() {
  local file model system_message user_message

  require_ask_tools
  if ! file=$(select_profile_file); then
    return 0
  fi
  if ! model=$(select_profile_model "$file"); then
    return 0
  fi
  system_message=$(prompt_value 'System message' 'You are a helpful assistant.')
  user_message=$(prompt_value 'User message' '' true)
  provider_chat_completion "$file" "$model" "$system_message" "$user_message"
}

ask_provider_cli() {
  local profile_name="$1"
  shift
  local file model='' system_message='You are a helpful assistant.' user_message=''

  while [ "$#" -gt 0 ]; do
    case "$1" in
    --model)
      if [ "$#" -lt 2 ]; then
        echo 'Error: --model requires a value' >&2
        exit 1
      fi
      model="$2"
      shift 2
      ;;
    --system-message)
      if [ "$#" -lt 2 ]; then
        echo 'Error: --system-message requires a value' >&2
        exit 1
      fi
      system_message="$2"
      shift 2
      ;;
    --system-message-file)
      if [ "$#" -lt 2 ]; then
        echo 'Error: --system-message-file requires a value' >&2
        exit 1
      fi
      if [ ! -r "$2" ]; then
        echo "Error: cannot read file: $2" >&2
        exit 1
      fi
      system_message=$(<"$2")
      shift 2
      ;;
    --message | --user-message)
      if [ "$#" -lt 2 ]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      user_message="$2"
      shift 2
      ;;
    --message-file | --user-message-file)
      if [ "$#" -lt 2 ]; then
        echo "Error: $1 requires a value" >&2
        exit 1
      fi
      if [ ! -r "$2" ]; then
        echo "Error: cannot read file: $2" >&2
        exit 1
      fi
      user_message=$(<"$2")
      shift 2
      ;;
    *)
      echo "Error: unknown ask option '$1'" >&2
      usage >&2
      exit 1
      ;;
    esac
  done

  if [ -z "$user_message" ]; then
    echo 'Error: ask requires --message or --user-message' >&2
    exit 1
  fi

  require_ask_tools
  file=$(require_existing_profile_file "$profile_name")

  if [ -n "$model" ]; then
    if ! profile_has_model "$file" "$model"; then
      echo "Error: model not configured for profile '$profile_name': $model" >&2
      exit 1
    fi
  else
    model=$(default_profile_model "$file")
  fi

  provider_chat_completion "$file" "$model" "$system_message" "$user_message"
}

ask_provider() {
  if [ "$#" -eq 0 ]; then
    ask_provider_interactive
    return 0
  fi

  ask_provider_cli "$@"
}

main() {
  case "${1:-}" in
  -h | --help | help | '')
    usage
    exit 0
    ;;
  -v | --version | version)
    print_version
    exit 0
    ;;
  create)
    shift
    create_profile "$@"
    ;;
  update)
    shift
    update_profile "$@"
    ;;
  list)
    shift
    list_profiles "$@"
    ;;
  read)
    shift
    read_profile "$@"
    ;;
  profiles)
    shift
    list_profile_names "$@"
    ;;
  models)
    shift
    list_profile_models "$@"
    ;;
  ask)
    shift
    ask_provider "$@"
    ;;
  delete)
    shift
    delete_profile "$@"
    ;;
  *)
    echo "Error: unknown command '$1'" >&2
    usage >&2
    exit 1
    ;;
  esac
}

main "$@"
