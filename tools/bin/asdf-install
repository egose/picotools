#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOAD_SH="${SCRIPT_DIR}/../lib/picotools/load.sh"
if [ ! -f "$LOAD_SH" ]; then
  LOAD_SH="${SCRIPT_DIR}/../../lib/picotools/load.sh"
fi
# shellcheck source=../../lib/picotools/load.sh
# shellcheck disable=SC1091
. "$LOAD_SH"
picotools_source_modules "$SCRIPT_DIR" commands version

usage() {
  cat <<'EOF'
Usage: asdf-install [tool-versions-file]

Adds missing asdf plugins, updates plugins, installs versions from a
.tool-versions file, and runs asdf reshim.

Options:
  -h, --help, help        Show this help message
  -v, --version, version  Show the tool version

Arguments:
  tool-versions-file      Path to the .tool-versions file (default: ./.tool-versions)
EOF
}

print_version() {
  picotools_print_version "$SCRIPT_DIR"
}

main() {
  local tool_versions_file=".tool-versions"

  case "${1:-}" in
  -h | --help | help)
    usage
    exit 0
    ;;
  -v | --version | version)
    print_version
    exit 0
    ;;
  "")
    ;;
  *)
    tool_versions_file="$1"
    ;;
  esac

  if [ ! -f "$tool_versions_file" ]; then
    echo "Error: file not found: $tool_versions_file" >&2
    exit 1
  fi

  picotools_require_command asdf

  cut -f 1 -d ' ' "$tool_versions_file" | xargs -n 1 asdf plugin add || true
  asdf plugin update --all

  while IFS= read -r line; do
    if [ -z "$line" ] || [ "${line#\#}" != "$line" ]; then
      continue
    fi

    tool=$(echo "$line" | awk '{print $1}')
    version=$(echo "$line" | awk '{print $2}')

    echo "Installing $tool $version..."
    asdf install "$tool" "$version"
  done <"$tool_versions_file"

  asdf reshim
}

main "$@"
