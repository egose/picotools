#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/../.." && pwd)"
VERSION_FILE="${ROOT_DIR}/VERSION"

usage() {
  cat <<'EOF'
Usage: pip-upgrade [requirements-file]

Updates requirement pins in a requirements file to the latest versions on PyPI.

Options:
  -h, --help, help        Show this help message
  -v, --version, version  Show the tool version

Arguments:
  requirements-file       Path to requirements file (default: ./requirements.txt)
EOF
}

print_version() {
  if [ -f "$VERSION_FILE" ]; then
    tr -d '[:space:]' <"$VERSION_FILE"
    printf '\n'
  else
    echo "unknown"
  fi
}

get_latest_version() {
  local base_name="${1%%\[*}"
  local response
  response=$(curl -sf --max-time 5 "https://pypi.org/pypi/${base_name}/json" 2>/dev/null) || return 1
  echo "$response" | grep -o '"version":"[^"]*"' | head -1 | cut -d'"' -f4
}

main() {
  local requirements_file="requirements.txt"
  local tmpfile stripped name latest

  case "${1:-}" in
  -h | --help | help)
    usage
    exit 0
    ;;
  -v | --version | version)
    print_version
    exit 0
    ;;
  "")
    ;;
  *)
    requirements_file="$1"
    ;;
  esac

  if [ ! -f "$requirements_file" ]; then
    echo "File not found: $requirements_file" >&2
    exit 1
  fi

  tmpfile=$(mktemp)
  trap 'rm -f "$tmpfile"' EXIT

  while IFS= read -r line || [ -n "$line" ]; do
    stripped=$(echo "$line" | sed 's/#.*//' | xargs)

    if [ -z "$stripped" ] || [[ "$line" =~ ^[[:space:]]*# ]]; then
      echo "$line" >>"$tmpfile"
      continue
    fi

    if [[ "$stripped" =~ ^([a-zA-Z0-9_.\-]+(\[[^\]+\]])?)[=\<\>!~]* ]]; then
      name="${BASH_REMATCH[1]}"
    else
      echo "$line" >>"$tmpfile"
      continue
    fi

    latest=$(get_latest_version "$name") || true
    if [ -z "${latest:-}" ]; then
      echo "$line" >>"$tmpfile"
      continue
    fi

    echo "${name}==${latest}" >>"$tmpfile"
  done <"$requirements_file"

  cp "$tmpfile" "$requirements_file"
  echo "${requirements_file} updated."
}

main "$@"
