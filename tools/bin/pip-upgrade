#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOAD_SH="${SCRIPT_DIR}/../lib/picotools/load.sh"
if [ ! -f "$LOAD_SH" ]; then
  LOAD_SH="${SCRIPT_DIR}/../../lib/picotools/load.sh"
fi
# shellcheck source=../../lib/picotools/load.sh
# shellcheck disable=SC1091
. "$LOAD_SH"
picotools_source_modules "$SCRIPT_DIR" commands prompt version

PIP_UPGRADE_TMPFILE=""

usage() {
  cat <<'EOF'
Usage: pip-upgrade [--yes] [--scope major|minor|patch] [requirements-file]

Updates exact requirement pins in a requirements file to newer versions on PyPI.

Options:
  --yes                     Update the requirements file without prompting
  --scope SCOPE             Allowed upgrade scope: major, minor, or patch
                            (default: major)
  -h, --help, help        Show this help message
  -v, --version, version  Show the tool version

Arguments:
  requirements-file       Path to requirements file (default: ./requirements.txt)
EOF
}

print_version() {
  picotools_print_version "$SCRIPT_DIR"
}

cleanup_tmpfile() {
  if [ -n "${PIP_UPGRADE_TMPFILE:-}" ]; then
    rm -f "$PIP_UPGRADE_TMPFILE"
  fi
}

select_target_version() {
  local name="$1"
  local current_version="$2"
  local scope="$3"
  local lookup_name="$name"
  local base_name
  local response

  lookup_name="${lookup_name#"${lookup_name%%[![:space:]]*}"}"
  base_name="${lookup_name%%\[*}"

  response=$(curl -sf --max-time 5 "https://pypi.org/pypi/${base_name}/json" 2>/dev/null) || return 1

  CURRENT_VERSION="$current_version" UPGRADE_SCOPE="$scope" python3 -c '
import json
import os
import sys

try:
    from packaging.version import InvalidVersion, Version
except Exception:
    try:
        from pip._vendor.packaging.version import InvalidVersion, Version
    except Exception:
        print("Error: no PEP 440 version parser is available", file=sys.stderr)
        sys.exit(1)


def normalized_prefix(parts, size):
    parts = tuple(parts)
    if len(parts) >= size:
        return parts[:size]
    return parts + (0,) * (size - len(parts))


try:
    payload = json.load(sys.stdin)
    current = Version(os.environ["CURRENT_VERSION"])
except InvalidVersion:
    sys.exit(1)

scope = os.environ["UPGRADE_SCOPE"]
releases = payload.get("releases") or {}
candidates = []

for raw_version, files in releases.items():
    if not files or all(file.get("yanked", False) for file in files):
        continue

    try:
        version = Version(raw_version)
    except InvalidVersion:
        continue

    if version.is_prerelease or version.is_devrelease:
        continue

    if version < current:
        continue

    if scope == "patch":
        if normalized_prefix(version.release, 2) != normalized_prefix(current.release, 2):
            continue
    elif scope == "minor":
        if normalized_prefix(version.release, 1) != normalized_prefix(current.release, 1):
            continue
    elif scope != "major":
        sys.exit(2)

    candidates.append(version)

if not candidates:
    print(os.environ["CURRENT_VERSION"])
    sys.exit(0)

print(max(candidates))
' <<<"$response"
}

main() {
  local requirements_file="requirements.txt"
  local assume_yes=false
  local scope="major"
  local tmpfile line name operator current_version target_version suffix

  while [ $# -gt 0 ]; do
    case "$1" in
    --yes)
      assume_yes=true
      shift
      ;;
    --scope)
      if [ $# -lt 2 ]; then
        echo "Error: missing value for $1" >&2
        exit 1
      fi

      scope="$2"
      shift 2
      ;;
    -h | --help | help)
      usage
      exit 0
      ;;
    -v | --version | version)
      print_version
      exit 0
      ;;
    *)
      if [ "$requirements_file" != "requirements.txt" ]; then
        echo "Error: unexpected argument: $1" >&2
        usage >&2
        exit 1
      fi

      requirements_file="$1"
      shift
      ;;
    esac
  done

  case "$scope" in
  major | minor | patch)
    ;;
  *)
    echo "Error: invalid scope '$scope'; expected one of: major, minor, patch" >&2
    exit 1
    ;;
  esac

  if [ ! -f "$requirements_file" ]; then
    echo "File not found: $requirements_file" >&2
    exit 1
  fi

  picotools_require_command python3

  tmpfile=$(mktemp)
  PIP_UPGRADE_TMPFILE="$tmpfile"
  trap 'cleanup_tmpfile' EXIT

  while IFS= read -r line || [ -n "$line" ]; do
    if [ -z "$line" ] || [[ "$line" =~ ^[[:space:]]*# ]]; then
      printf '%s\n' "$line" >>"$tmpfile"
      continue
    fi

    if [[ "$line" =~ ^([[:space:]]*[A-Za-z0-9_.-]+(\[[^]]+\])?)(===|==)([^[:space:]#;]+)(.*)$ ]]; then
      name="${BASH_REMATCH[1]}"
      operator="${BASH_REMATCH[3]}"
      current_version="${BASH_REMATCH[4]}"
      suffix="${BASH_REMATCH[5]}"
    else
      printf '%s\n' "$line" >>"$tmpfile"
      continue
    fi

    target_version=$(select_target_version "$name" "$current_version" "$scope") || true
    if [ -z "${target_version:-}" ]; then
      printf '%s\n' "$line" >>"$tmpfile"
      continue
    fi

    printf '%s%s%s%s\n' "$name" "$operator" "$target_version" "$suffix" >>"$tmpfile"
  done <"$requirements_file"

  if cmp -s "$tmpfile" "$requirements_file"; then
    echo "No updates found."
    exit 0
  fi

  if [ "$assume_yes" != true ]; then
    picotools_confirm_action "Proceed with updating ${requirements_file}?" || exit 1
  fi

  cp "$tmpfile" "$requirements_file"
  echo "${requirements_file} updated."
}

main "$@"
